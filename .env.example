# Copy this file to .env and fill in your credentials
# cp .env.example .env

# SMTP — for email notifications (notify.sh)
# Port 587 → uses STARTTLS (smtp://)
# Port 465 → uses implicit TLS (smtps://) — change port below accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username@gmail.com   # used for authentication
SMTP_FROM=sender@yourdomain.com          # address shown in From: (can differ from SMTP_USER)
SMTP_PASS=your-app-password              # Gmail: use an App Password, not your real password
NOTIFY_TO=you@yourdomain.com

# Source IMAP server
IMAP_SRC_HOST=imap.source.com

# Destination IMAP server
IMAP_DST_HOST=imap.dest.com

# Account credentials: user1
USER1_SRC=user1@example.com
USER1_SRC_PASS=changeme
USER1_DST=user1@newdomain.com
USER1_DST_PASS=changeme

# Account credentials: user2
USER2_SRC=user2@example.com
USER2_SRC_PASS=changeme
USER2_DST=user2@newdomain.com
USER2_DST_PASS=changeme

# Account credentials: user3
USER3_SRC=user3@example.com
USER3_SRC_PASS=changeme
USER3_DST=user3@newdomain.com
USER3_DST_PASS=changeme
